# Dois Proxmox independentes (mesmo padrão que terraform/envs/runners).
# O path da API deve incluir /api2/json.
proxmox_pve1_endpoint  = "https://192.168.1.10:8006/api2/json"
proxmox_pve1_api_token = "terraform@pve!github-actions=CHANGE_ME"

proxmox_pve2_endpoint  = "https://192.168.1.20:8006/api2/json"
proxmox_pve2_api_token = "terraform@pve!github-actions=CHANGE_ME"

# Prefer false when o certificado da API for confiável.
proxmox_tls_insecure = true

ssh_public_key = "ssh-ed25519 CHANGE_ME"

# Topologia em locals.tf: 1 control-plane (k8s-cp-01) + 2 workers (k8s-worker-01/02).
# O campo proxmox_node por VM tem de ser "pve1" ou "pve2" (nome do nó no Proxmox).

# Template a clonar (VMID) em **cada** host — o Packer deste repo usa 9000 nos dois.
# kubernetes_template_vm_id = 9000
# kubernetes_dns_servers    = ["192.168.1.1", "1.1.1.1"]
# kubernetes_datastore_id   = "local-lvm"
# kubernetes_network_bridge = "vmbr0"
# Utilizador no template Packer deste repo (autoinstall); se mudares o template, ajusta.
# kubernetes_cloud_init_username = "packer"
