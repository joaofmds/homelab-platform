# Duas APIs Proxmox. Tokens precisam de VM.Clone em /vms/<template> + disco/pool.
# Nó Proxmox (hostname) por VM: edita envs/runners/locals.tf (proxmox_node);
# tem de coincidir com o nome na árvore (ex. pve1, pve2).
proxmox_pve1_endpoint  = "https://192.168.1.10:8006/api2/json"
proxmox_pve1_api_token = "USER@REALM!TOKEN_ID=CHANGE_ME_PVE1"

proxmox_pve2_endpoint  = "https://192.168.1.20:8006/api2/json"
proxmox_pve2_api_token = "USER@REALM!TOKEN_ID=CHANGE_ME_PVE2"

proxmox_tls_insecure = true

ssh_public_key = "ssh-ed25519 CHANGE_ME"

# VMID do template em CADA Proxmox (clone). O 9000 é o default do repo (Packer).
# Só funciona depois de existir essa VM/template no host — senão cria com Packer
# (packer/ubuntu-2404) ou à mão e ajusta este número ao VMID real.
# runner_template_vm_id = 9000
# runner_dns_servers    = ["192.168.1.1", "1.1.1.1"]
# runner_datastore_id   = "local-lvm"
# runner_network_bridge = "vmbr0"
