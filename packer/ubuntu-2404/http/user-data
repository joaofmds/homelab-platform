#cloud-config
autoinstall:
  version: 1

  locale: en_US.UTF-8
  keyboard:
    layout: us

  identity:
    hostname: ubuntu-2404-k8s-template
    username: packer
    password: "__SSH_PASSWORD_HASH__"

  ssh:
    install-server: true
    allow-pw: true

  packages:
    - qemu-guest-agent
    - cloud-init
    - curl
    - ca-certificates
    - gnupg

  storage:
    layout:
      name: direct

  user-data:
    disable_root: true
    package_update: true
    timezone: America/Sao_Paulo
    users:
      - name: packer
        groups: sudo
        shell: /bin/bash
        sudo: ALL=(ALL) NOPASSWD:ALL
        lock_passwd: false
